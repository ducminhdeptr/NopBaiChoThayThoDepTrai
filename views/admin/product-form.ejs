<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= mode === 'create' ? 'Thêm sản phẩm' : 'Sửa sản phẩm' %> • Admin • Coffee Shop</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- SweetAlert2 -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="/css/admin.css" />
  </head>

  <body>
    <div class="admin-layout">
      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-brand">
          <div class="brand-mark">☕</div>
          <div class="brand-text">
            <div class="brand-title">KOREA • CAFE</div>
            <div class="brand-sub">Admin Dashboard</div>
          </div>
        </div>

        <nav class="sidebar-nav">
          <a class="sidebar-link" href="/admin">
            <i class="bi bi-speedometer2"></i>
            <span>Dashboard</span>
          </a>

          <a class="sidebar-link active" href="/admin/products/new">
            <i class="bi bi-cup-hot"></i>
            <span>Quản lý sản phẩm</span>
          </a>

          <a class="sidebar-link" href="#" onclick="return false;">
            <i class="bi bi-tag"></i>
            <span>Danh mục</span>
          </a>

          <a class="sidebar-link logout" href="#" onclick="return false;">
            <i class="bi bi-box-arrow-right"></i>
            <span>Logout</span>
          </a>
        </nav>
      </aside>

      <section class="admin-main">
        <header class="admin-topbar">
          <div class="admin-topbar-left">
            <div class="page-title"><%= mode === 'create' ? 'Thêm sản phẩm' : 'Sửa sản phẩm' %></div>
            <div class="page-sub">Validate • Preview • Upload</div>
          </div>

          <div class="admin-topbar-right">
            <a class="btn btn-soft" href="/admin">
              <i class="bi bi-arrow-left"></i> Quay lại
            </a>
          </div>
        </header>

        <div class="admin-card">
          <div class="admin-card-head">
            <div>
              <div class="admin-card-title">Thông tin sản phẩm</div>
              <div class="admin-card-sub">Chỉ hỗ trợ ảnh JPG/PNG/WEBP (max 2MB)</div>
            </div>
          </div>

          <% const actionUrl = mode === 'create' ? '/admin/products' : '/admin/products/' + product.id; %>

          <form class="admin-form" action="<%= actionUrl %>" method="post" enctype="multipart/form-data" novalidate>
            <div class="row g-3">
              <div class="col-lg-4">
                <div class="form-section">
                  <label class="form-label">Ảnh hiện tại</label>
                  <div class="preview-card">
                    <img
                      id="imagePreview"
                      src="<%= product && product.image_url ? product.image_url : 'https://images.unsplash.com/photo-1511920170033-f8396924c348?auto=format&fit=crop&w=600&q=80' %>"
                      alt="Preview ảnh"
                    />
                  </div>

                  <label class="form-label mt-3">Upload ảnh mới</label>
                  <input class="form-control" type="file" name="image" id="imageInput" accept="image/*" />
                  <div class="form-hint">Ảnh sẽ được lưu vào <span class="mono">public/uploads</span>.</div>
                </div>
              </div>

              <div class="col-lg-8">
                <div class="form-section">
                  <div class="mb-3">
                    <label class="form-label">Tên sản phẩm</label>
                    <input
                      type="text"
                      class="form-control"
                      name="name"
                      value="<%= product ? product.name : '' %>"
                      placeholder="VD: Cà phê sữa đá"
                      required
                    />
                    <div class="invalid-feedback d-block">
                      <% if (errors) { %>
                        <% const e = errors.find(x => x.param === 'name'); %>
                        <%= e ? e.msg : '' %>
                      <% } %>
                    </div>
                  </div>

                  <div class="mb-3">
                    <label class="form-label">Giá (VNĐ)</label>
                    <input
                      type="number"
                      class="form-control"
                      name="price"
                      value="<%= product ? product.price : '' %>"
                      placeholder="VD: 45000"
                      min="1"
                      step="1000"
                      required
                    />
                    <div class="invalid-feedback d-block">
                      <% if (errors) { %>
                        <% const e = errors.find(x => x.param === 'price'); %>
                        <%= e ? e.msg : '' %>
                      <% } %>
                    </div>
                  </div>

                  <div class="mb-3">
                    <label class="form-label">Danh mục</label>
                    <select class="form-select" name="category_id" required>
                      <% categories.forEach(c => { %>
                        <option value="<%= c.id %>" <%= product && String(product.category_id) === String(c.id) ? 'selected' : '' %>>
                          <%= c.name %>
                        </option>
                      <% }) %>
                    </select>
                    <div class="invalid-feedback d-block">
                      <% if (errors) { %>
                        <% const e = errors.find(x => x.param === 'category_id'); %>
                        <%= e ? e.msg : '' %>
                      <% } %>
                    </div>
                  </div>

                  <div class="mb-3">
                    <label class="form-label">Mô tả</label>
                    <textarea
                      class="form-control"
                      name="description"
                      rows="4"
                      placeholder="Mô tả ngắn..."
                      required
                    ><%= product ? product.description : '' %></textarea>
                    <div class="invalid-feedback d-block">
                      <% if (errors) { %>
                        <% const e = errors.find(x => x.param === 'description'); %>
                        <%= e ? e.msg : '' %>
                      <% } %>
                    </div>
                  </div>

                  <div class="mb-3">
                    <label class="form-label">Trạng thái</label>
                    <select class="form-select" name="status">
                      <option value="active" <%= product && product.status === 'active' ? 'selected' : '' %>>Còn hàng</option>
                      <option value="out_of_stock" <%= product && product.status === 'out_of_stock' ? 'selected' : '' %>>Hết hàng</option>
                    </select>
                  </div>

                  <div class="form-actions">
                    <button class="btn btn-primary btn-anim" type="submit">
                      <i class="bi bi-check2-circle"></i>
                      <%= mode === 'create' ? 'Thêm sản phẩm' : 'Lưu thay đổi' %>
                    </button>
                    <button class="btn btn-ghost" type="reset">
                      <i class="bi bi-arrow-counterclockwise"></i> Làm mới
                    </button>
                  </div>

                  <% if (errors && errors.length) { %>
                    <div class="alert alert-danger mt-3">
                      <ul class="mb-0">
                        <% errors.forEach(er => { %>
                          <li><%= er.msg %></li>
                        <% }) %>
                      </ul>
                    </div>
                  <% } %>

                </div>
              </div>
            </div>
          </form>
        </div>

        <div class="admin-footer">
          <span>© <%= new Date().getFullYear() %> KOREA • CAFE</span>
          <span class="sep">•</span>
          <span>Premium Asian Modern UI</span>
        </div>
      </section>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <script src="/js/admin.js"></script>
  </body>
</html>
